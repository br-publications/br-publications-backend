# Server Configuration
NODE_ENV=development
PORT=5000

# Super Admin Configuration (Set these in Render environment or local .env)
SUPER_ADMIN_EMAIL=your_admin_email@example.com
SUPER_ADMIN_USERNAME=admin_username
SUPER_ADMIN_PASSWORD=your_strong_password_here

# Database Configuration (PostgreSQL)
# For Render: Use the internal database connection string
# For Local: localhost with your postgres credentials
DB_HOST=localhost
DB_PORT=5432
DB_NAME=br_publications_development
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# JWT Configuration
# Generate a strong random string (min 32 characters) for production
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_characters
JWT_EXPIRES_IN=5h

# Email Configuration (Gmail Example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
FRONTEND_URL=https://your-frontend-domain.com

# Category-Specific Email Configurations
# If left blank, these will fallback to the default EMAIL_HOST/USER/PASSWORD above
# Use these if you want different email providers for different submission types

# Book Chapter Emails
EMAIL_HOST_BOOK_CHAPTER=
EMAIL_PORT_BOOK_CHAPTER=
EMAIL_USER_BOOK_CHAPTER=
EMAIL_PASS_BOOK_CHAPTER=
EMAIL_FROM_BOOK_CHAPTER=

# Textbook Emails
EMAIL_HOST_TEXTBOOK=
EMAIL_PORT_TEXTBOOK=
EMAIL_USER_TEXTBOOK=
EMAIL_PASS_TEXTBOOK=
EMAIL_FROM_TEXTBOOK=

# Recruitment Emails
EMAIL_HOST_RECRUITMENT=
EMAIL_PORT_RECRUITMENT=
EMAIL_USER_RECRUITMENT=
EMAIL_PASS_RECRUITMENT=
EMAIL_FROM_RECRUITMENT=

# Project/Internship Emails
EMAIL_HOST_PROJECT=
EMAIL_PORT_PROJECT=
EMAIL_USER_PROJECT=
EMAIL_PASS_PROJECT=
EMAIL_FROM_PROJECT=
# Google OAuth Configuration
# Get these from Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# CORS Configuration
# For local development, use http://localhost:PORT
# For production, use your frontend domain
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
MAX_OTP_ATTEMPTS=5
OTP_EXPIRY_MINUTES=10

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# API Documentation
API_DOCS_ENABLED=true

# ============================================================================
# HOW TO USE THIS FILE:
# ============================================================================
#
# LOCAL DEVELOPMENT:
# 1. Copy this file: cp .env.example .env
# 2. Update .env with your local values (real secrets are OK for local dev)
# 3. Add .env to .gitignore (it's already there)
# 4. Never commit .env to git
#
# PRODUCTION (Render.com):
# 1. Do NOT add real secrets to this file - keep only placeholders
# 2. Set all environment variables in Render Dashboard > Environment
# 3. Commit .env.example to git for documentation
# 4. Render will inject environment variables at runtime
# ============================================================================
