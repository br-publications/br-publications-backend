# Google OAuth Configuration
GOOGLE_CLIENT_ID=''
GOOGLE_CLIENT_SECRET=''

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
MAX_OTP_ATTEMPTS=5
