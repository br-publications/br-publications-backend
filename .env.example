# Server Configuration
NODE_ENV=development
PORT=5000

# Super Admin Configuration
SUPER_ADMIN_EMAIL=publications.br.app@gmail.com
SUPER_ADMIN_USERNAME=br_publications
SUPER_ADMIN_PASSWORD=BRpublications@app

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=br_publications_development
DB_USER=postgres
DB_PASSWORD=admin

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_characters
JWT_EXPIRES_IN=5h

# Email Configuration (Gmail Example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=publications.br.app@gmail.com
EMAIL_PASSWORD=ehbosizeingzldei
FRONTEND_URL=https://www.brpublications.com

# Category-Specific Email Configurations
# If left blank, these will fallback to the default EMAIL_HOST/USER/PASSWORD above

# Book Chapter Emails
EMAIL_HOST_BOOK_CHAPTER=
EMAIL_PORT_BOOK_CHAPTER=
EMAIL_USER_BOOK_CHAPTER=
EMAIL_PASS_BOOK_CHAPTER=
EMAIL_FROM_BOOK_CHAPTER=

# Textbook Emails
EMAIL_HOST_TEXTBOOK=
EMAIL_PORT_TEXTBOOK=
EMAIL_USER_TEXTBOOK=
EMAIL_PASS_TEXTBOOK=
EMAIL_FROM_TEXTBOOK=

# Recruitment Emails
EMAIL_HOST_RECRUITMENT=
EMAIL_PORT_RECRUITMENT=
EMAIL_USER_RECRUITMENT=
EMAIL_PASS_RECRUITMENT=
